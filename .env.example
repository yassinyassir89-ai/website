# ============================================
# Database (Supabase PostgreSQL)
# ============================================
# Get from: Supabase Dashboard → Project Settings → Database → Connection string → URI
# Replace [YOUR-PASSWORD] with your actual database password
DATABASE_URL="postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# ============================================
# Supabase Storage (image uploads)
# ============================================
# Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
# Service role key (server-side only — keeps it secret!)
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ============================================
# NextAuth
# ============================================
NEXTAUTH_URL="http://localhost:3001"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-min-32-characters"

# ============================================
# Admin Panel
# ============================================
# Password to access /admin/builder. CHANGE THIS in production!
# Default fallback if not set: growbeauty2026
ADMIN_PASSWORD="growbeauty2026"

# ============================================
# App
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="Grow Beauty"
